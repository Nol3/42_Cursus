# ==========================================
# ENV CONFIGURATION FOR FT_TRANSCENDENCE
# ==========================================

# General
DEBUG=false
ENVIRONMENT=development

# ==========================================
# BACKEND (Django) Configuration
# ==========================================

# Django settings
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,*.transcendence.local

# Database
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# If using PostgreSQL (optional):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=transcendence_db
# DB_USER=transcendence_user
# DB_PASSWORD=your-db-password
# DB_HOST=postgres
# DB_PORT=5432

# Authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Vault. USE_VAULT=true makes the backend read secrets from Vault; set false to
# use the env vars above (e.g. local `manage.py runserver`). The backend
# authenticates via AppRole (creds written by vault-init to the vault_creds
# volume); VAULT_TOKEN is only a manual/dev fallback if AppRole is unavailable.
USE_VAULT=true
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Email (for password reset, notifications)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://localhost:4200,http://localhost:3000

# Backend Port
BACKEND_PORT=8000

# ==========================================
# FRONTEND (Angular) Configuration
# ==========================================

# Frontend environment
NG_ENV=development
FRONTEND_PORT=4200
BACKEND_URL=http://localhost:8000
API_URL=http://backend:8000

# ==========================================
# Docker Configuration
# ==========================================

# Compose project name
COMPOSE_PROJECT_NAME=ft_transcendence

# Host ports (all >1024 — no sudo/privileged ports required). Override any that
# clash with other services already running on the machine.
HTTPS_PORT=8443
HTTP_PORT=8080
VAULT_PORT=8200

# Data persistence
DATA_DIR=./docker/volumes
